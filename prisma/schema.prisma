  affiliate_affiliates affiliate_affiliates                  @relation(fields: [affiliate_id], references: [id], onUpdate: NoAction, map: "fk_conv_aff")
  auth_users           auth_users                            @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_conv_user")

  @@index([affiliate_id, created_at], map: "idx_aff_conv_aff_time")
  @@index([user_id, created_at], map: "idx_aff_conv_user_time")
}

model affiliate_payouts {
  id                   String               @id @default(dbgenerated("(uuid())")) @db.Char(36)
