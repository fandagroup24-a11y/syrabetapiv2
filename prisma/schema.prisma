generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model admin_admin_actions {
  id                String            @id @default(dbgenerated("(uuid())")) @db.Char(36)
  admin_user_id     String            @db.Char(36)
  action            String            @db.Text
  entity_type       String            @db.Text
  entity_id         String?           @db.Text
  before_json       Json?
  after_json        Json?
  ip                String?           @db.Text
  created_at        DateTime          @default(now()) @db.Timestamp(0)
  admin_admin_users admin_admin_users @relation(fields: [admin_user_id], references: [id], onUpdate: NoAction, map: "fk_admin_actions_admin")

  @@index([admin_user_id, created_at], map: "idx_admin_actions_admin")
  @@index([created_at], map: "idx_admin_actions_created")
}

model admin_admin_users {
  id                  String                   @id @default(dbgenerated("(uuid())")) @db.Char(36)
  email               String                   @unique(map: "uq_admin_email") @db.VarChar(255)
  password_hash       String                   @db.Text
  role_id             String?                  @db.Char(36)
  display_name        String?                  @db.VarChar(255)
  status              admin_admin_users_status @default(ACTIVE)
  permissions_json    Json
  created_at          DateTime                 @default(now()) @db.Timestamp(0)
  updated_at          DateTime                 @default(now()) @db.Timestamp(0)
  admin_admin_actions admin_admin_actions[]
  admin_roles         admin_roles?             @relation(fields: [role_id], references: [id], onUpdate: NoAction, map: "fk_admin_role")
  obs_fraud_signals   obs_fraud_signals[]

  @@index([role_id], map: "fk_admin_role")
}

model admin_risk_limits {
  id         String   @id @default(dbgenerated("(uuid())")) @db.Char(36)
  scope      String   @db.VarChar(20)
  scope_key  String?  @db.VarChar(255)
  name       String   @db.VarChar(255)
  value_json Json
  status     String   @default("ACTIVE") @db.VarChar(20)
  created_at DateTime @default(now()) @db.Timestamp(0)
  updated_at DateTime @default(now()) @db.Timestamp(0)

  @@unique([scope, scope_key, name], map: "uq_risk_scope")
}

model admin_roles {
  id                String              @id @default(dbgenerated("(uuid())")) @db.Char(36)
  name              String              @unique(map: "uq_role_name") @db.VarChar(100)
  description       String?             @db.Text
  permissions_json  Json
  is_system         Boolean             @default(false)
  created_at        DateTime            @default(now()) @db.Timestamp(0)
  updated_at        DateTime            @default(now()) @db.Timestamp(0)
  admin_admin_users admin_admin_users[]
}

model affiliate_affiliate_clicks {
  id                        String                    @id @default(dbgenerated("(uuid())")) @db.Char(36)
  affiliate_link_id         String                    @db.Char(36)
  session_id                String?                   @db.VarChar(255)
  ip_hash                   String?                   @db.Text
  user_agent                String?                   @db.Text
  referrer                  String?                   @db.Text
  utm_json                  Json?
  clicked_at                DateTime                  @default(now()) @db.Timestamp(0)
  affiliate_affiliate_links affiliate_affiliate_links @relation(fields: [affiliate_link_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_aff_clicks_link")
  affiliate_attributions    affiliate_attributions[]

  @@index([affiliate_link_id, clicked_at], map: "idx_aff_clicks_link_time")
}

model affiliate_affiliate_links {
  id                         String                       @id @default(dbgenerated("(uuid())")) @db.Char(36)
  affiliate_id               String                       @db.Char(36)
  code                       String                       @unique(map: "uq_aff_link_code") @db.VarChar(100)
  landing_url                String?                      @db.Text
  campaign                   String?                      @db.VarChar(255)
  created_at                 DateTime                     @default(now()) @db.Timestamp(0)
  affiliate_affiliate_clicks affiliate_affiliate_clicks[]
  affiliate_affiliates       affiliate_affiliates         @relation(fields: [affiliate_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_aff_links_aff")

  @@index([affiliate_id], map: "idx_aff_links_aff")
}

model affiliate_affiliates {
  id                        String                      @id @default(dbgenerated("(uuid())")) @db.Char(36)
  name                      String                      @db.VarChar(255)
  status                    String                      @default("ACTIVE") @db.VarChar(20)
  created_at                DateTime                    @default(now()) @db.Timestamp(0)
  affiliate_affiliate_links affiliate_affiliate_links[]
  affiliate_attributions    affiliate_attributions[]
  affiliate_commissions     affiliate_commissions[]
  affiliate_conversions     affiliate_conversions[]
  affiliate_payouts         affiliate_payouts[]
}

model affiliate_attributions {
  id                         String                       @id @default(dbgenerated("(uuid())")) @db.Char(36)
  affiliate_id               String                       @db.Char(36)
  click_id                   String?                      @db.Char(36)
  user_id                    String                       @unique(map: "uq_attrib_user") @db.Char(36)
  model                      affiliate_attributions_model @default(LAST_CLICK)
  attributed_at              DateTime                     @default(now()) @db.Timestamp(0)
  expires_at                 DateTime                     @db.Timestamp(0)
  affiliate_affiliates       affiliate_affiliates         @relation(fields: [affiliate_id], references: [id], onUpdate: NoAction, map: "fk_attrib_aff")
  affiliate_affiliate_clicks affiliate_affiliate_clicks?  @relation(fields: [click_id], references: [id], onUpdate: NoAction, map: "fk_attrib_click")
  auth_users                 auth_users                   @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_attrib_user")

  @@index([click_id], map: "fk_attrib_click")
  @@index([affiliate_id, attributed_at], map: "idx_attrib_aff")
}

model affiliate_commissions {
  id                   String               @id @default(dbgenerated("(uuid())")) @db.Char(36)
  affiliate_id         String               @db.Char(36)
  period               String               @db.VarChar(20)
  model_json           Json
  amount               Decimal              @default(0.00) @db.Decimal(18, 2)
  status               String               @default("OPEN") @db.VarChar(20)
  created_at           DateTime             @default(now()) @db.Timestamp(0)
  affiliate_affiliates affiliate_affiliates @relation(fields: [affiliate_id], references: [id], onUpdate: NoAction, map: "fk_comm_aff")

  @@unique([affiliate_id, period], map: "uq_aff_comm_period")
}

model affiliate_conversions {
  id                   String                                @id @default(dbgenerated("(uuid())")) @db.Char(36)
  affiliate_id         String                                @db.Char(36)
  user_id              String                                @db.Char(36)
